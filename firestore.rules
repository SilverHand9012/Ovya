rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;

      match /symptomLogs/{docId} {
        allow read: if request.auth != null
                    && request.auth.uid == userId;

        allow write: if request.auth != null
                     && request.auth.uid == userId
                     && request.resource.data.keys().hasOnly([
                          'clientId',
                          'timestamp',
                          'updatedAt',
                          'isDeleted',
                          'deviceId',
                          'syncedAt',
                          'docId',
                          'notes',
                          'irregularCycle',
                          'acne',
                          'weightGain',
                          'hairGrowth',
                          'moodIssues',
                          'hairThinning',
                          'skinDarkening',
                          'fatigue',
                          'sleepProblems',
                          'bloating',
                          'familyHistory',
                          'difficultyConceiving'
                        ])
                     && request.resource.data.clientId is string;
      }

      // Covers all future subcollections
      match /{subcollection}/{docId} {
        allow read, write: if request.auth != null
                           && request.auth.uid == userId;
      }
    }
  }
}
